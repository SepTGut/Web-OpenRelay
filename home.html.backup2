<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>OpenRelay — Kontroler Relay IoT Open Source</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg-dark: #000000;
      --bg-darker: #0a0a0a;
      --bg-card: rgba(10, 10, 10, 0.6);
      --neon-cyan: #00ffff;
      --neon-magenta: #ff00ff;
      --neon-yellow: #ffff00;
      --neon-pink: #ff00ff;
      --text-primary: #e0e0e0;
      --text-secondary: #a0a0a0;
      --border-neon: rgba(0, 255, 255, 0.3);
      --shadow-neon: 0 0 10px rgba(0, 255, 255, 0.5),
                     0 0 20px rgba(0, 255, 255, 0.3),
                     0 0 30px rgba(0, 255, 255, 0.2);
      --shadow-neon-strong: 0 0 15px rgba(0, 255, 255, 0.8),
                            0 0 25px rgba(0, 255, 255, 0.5),
                            0 0 35px rgba(0, 255, 255, 0.3);
      --font-primary: 'Orbitron', monospace;
      --font-secondary: 'Inter', sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--bg-dark);
      color: var(--text-primary);
      font-family: var(--font-secondary);
      line-height: 1.7;
      overflow-x: hidden;
      position: relative;
      background-image:
        radial-gradient(circle at 20% 30%, rgba(0, 255, 255, 0.05) 0%, transparent 20%),
        radial-gradient(circle at 80% 70%, rgba(255, 0, 255, 0.05) 0%, transparent 20%),
        repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(0, 255, 255, 0.02) 10px, rgba(0, 255, 255, 0.02) 20px);
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23000"/><path d="M0 50 L100 50 M50 0 L50 100" stroke="%2300ffff" stroke-width="0.5" opacity="0.1"/></svg>');
      opacity: 0.3;
      pointer-events: none;
      z-index: -1;
    }

    /* Scan lines effect */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.1) 2px,
        rgba(0, 0, 0, 0.1) 4px
      );
      pointer-events: none;
      z-index: 999;
      opacity: 0.2;
    }

    h1, h2, h3, h4 {
      font-family: var(--font-primary);
      color: var(--text-primary);
      text-shadow: var(--shadow-neon);
      letter-spacing: -0.5px;
    }

    a {
      text-decoration: none;
      color: var(--text-primary);
      transition: all 0.3s ease;
    }

    a:hover {
      color: var(--neon-cyan);
      text-shadow: 0 0 5px var(--neon-cyan);
    }

    /* Container */
    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* Header */
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border-neon);
      z-index: 1000;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .logo-icon {
      width: 40px;
      height: 40px;
      background: var(--neon-cyan);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: pulse 2s infinite;
      box-shadow: var(--shadow-neon);
    }

    .logo-text {
      font-family: var(--font-primary);
      font-size: 1.5rem;
      background: linear-gradient(to right, var(--neon-cyan), var(--neon-magenta));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    nav ul {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    nav a {
      font-size: 1rem;
      font-weight: 500;
      position: relative;
      padding: 0.5rem 0;
    }

    nav a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--neon-cyan);
      transition: width 0.3s ease;
    }

    nav a:hover::after {
      width: 100%;
    }

    .cta-button {
      background: var(--neon-magenta);
      color: var(--bg-dark);
      border: none;
      padding: 0.75rem 1.5rem;
      font-family: var(--font-primary);
      font-weight: 600;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: var(--shadow-neon-strong);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .cta-button:hover {
      background: var(--neon-yellow);
      transform: translateY(-3px);
      box-shadow: 0 0 15px var(--neon-yellow),
              0 0 25px var(--neon-yellow);
    }

    /* Hero Section */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 80px 2rem 60px;
      position: relative;
      overflow: hidden;
    }

    .hero-content {
      max-width: 800px;
      z-index: 10;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: rgba(0, 255, 255, 0.1);
      border: 1px solid var(--border-neon);
      border-radius: 50px;
      padding: 0.5rem 1.5rem;
      font-size: 0.9rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 2rem;
      animation: pulse 3s infinite;
    }

    .badge-dot {
      width: 8px;
      height: 8px;
      background: var(--neon-magenta);
      border-radius: 50%;
      animation: blink 1.5s infinite;
    }

    .hero h1 {
      font-size: clamp(3rem, 8vw, 5rem);
      margin-bottom: 1.5rem;
      line-height: 1.1;
      background: linear-gradient(to right, var(--neon-cyan), var(--neon-magenta), var(--neon-yellow));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .hero-subtitle {
      font-size: 1.25rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto 2.5rem;
      line-height: 1.6;
    }

    .hero-actions {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-primary {
      background: var(--neon-cyan);
      color: var(--bg-dark);
      border: none;
      padding: 1rem 2rem;
      font-family: var(--font-primary);
      font-weight: 600;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: var(--shadow-neon);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .btn-primary:hover {
      background: var(--neon-magenta);
      transform: translateY(-2px);
      box-shadow: var(--shadow-neon-strong);
    }

    .btn-outline {
      background: transparent;
      color: var(--text-primary);
      border: 2px solid var(--border-neon);
      padding: 1rem 2rem;
      font-family: var(--font-primary);
      font-weight: 600;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .btn-outline:hover {
      background: var(--neon-cyan);
      color: var(--bg-dark);
      transform: translateY(-2px);
      box-shadow: var(--shadow-neon);
    }

    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 3rem;
      margin-top: 3rem;
      flex-wrap: wrap;
    }

    .stat {
      text-align: center;
    }

    .stat-value {
      font-family: var(--font-primary);
      font-size: 2.5rem;
      display: block;
      background: linear-gradient(to right, var(--neon-cyan), var(--neon-magenta));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .stat-label {
      font-size: 0.9rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 0.5rem;
    }

    /* Relay Visualizer */
    .relay-visualizer {
      margin-top: 3rem;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1rem;
    }

    .relay-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--bg-card);
      border: 1px solid var(--border-neon);
      transition: all 0.3s ease;
    }

    .relay-dot.active {
      background: var(--neon-cyan);
      box-shadow: var(--shadow-neon-strong);
      transform: scale(1.2);
    }

    .relay-dot.warning {
      background: var(--neon-yellow);
      box-shadow: 0 0 10px var(--neon-yellow);
    }

    .relay-dot.error {
      background: var(--neon-magenta);
      box-shadow: 0 0 10px var(--neon-magenta);
    }

    /* Sections */
    section {
      padding: 8rem 2rem;
      position: relative;
    }

    section:nth-child(even) {
      background: rgba(10, 10, 10, 0.3);
    }

    .section-header {
      text-align: center;
      margin-bottom: 4rem;
    }

    .section-tag {
      font-family: var(--font-primary);
      font-size: 0.9rem;
      color: var(--neon-cyan);
      text-transform: uppercase;
      letter-spacing: 2px;
      display: inline-block;
      margin-bottom: 1rem;
      position: relative;
    }

    .section-tag::after {
      content: '';
      position: absolute;
      bottom: -5px;
      left: 50%;
      transform: translateX(-50%);
      width: 30px;
      height: 2px;
      background: var(--neon-cyan);
    }

    .section-title {
      font-size: clamp(2rem, 5vw, 3.5rem);
      margin-bottom: 1.5rem;
      position: relative;
      display: inline-block;
    }

    .section-title::after {
      content: '';
      position: absolute;
      bottom: -10px;
      left: 0;
      width: 50px;
      height: 4px;
      background: var(--neon-magenta);
    }

    .section-description {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto;
      line-height: 1.8;
    }

    /* About Section */
    .about-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    .about-text {
      font-size: 1.125rem;
      color: var(--text-secondary);
      line-height: 1.8;
    }

    .about-text p {
      margin-bottom: 1.5rem;
    }

    .about-text strong {
      color: var(--text-primary);
    }

    .about-specs {
      background: var(--bg-card);
      border-radius: 20px;
      padding: 2rem;
      border: 1px solid var(--border-neon);
      box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
    }

    .spec-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(0, 255, 255, 0.1);
    }

    .spec-item:last-child {
      border-bottom: none;
    }

    .spec-label {
      font-size: 1rem;
      color: var(--text-secondary);
    }

    .spec-value {
      font-family: var(--font-primary);
      font-size: 1.125rem;
      color: var(--neon-cyan);
    }

    /* Features Section */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }

    .feature-card {
      background: var(--bg-card);
      border-radius: 20px;
      padding: 2.5rem;
      border: 1px solid var(--border-neon);
      transition: all 0.4s ease;
      position: relative;
      overflow: hidden;
    }

    .feature-card:hover {
      transform: translateY(-10px);
      box-shadow: var(--shadow-neon-strong);
      border-color: var(--neon-cyan);
    }

    .feature-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(to right, var(--neon-cyan), var(--neon-magenta), var(--neon-yellow));
    }

    .feature-icon {
      width: 60px;
      height: 60px;
      background: var(--neon-cyan);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-center;
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      box-shadow: var(--shadow-neon);
      animation: float 3s ease-in-out infinite;
    }

    .feature-card:nth-child(2) .feature-icon {
      background: var(--neon-magenta);
      box-shadow: 0 0 10px var(--neon-magenta);
    }

    .feature-card:nth-child(3) .feature-icon {
      background: var(--neon-yellow);
      box-shadow: 0 0 10px var(--neon-yellow);
    }

    .feature-card:nth-child(4) .feature-icon {
      background: var(--neon-pink);
      box-shadow: 0 0 10px var(--neon-pink);
    }

    .feature-title {
      font-family: var(--font-primary);
      font-size: 1.5rem;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .feature-title::after {
      content: '';
      flex-grow: 1;
      height: 2px;
      background: var(--border-neon);
    }

    .feature-description {
      color: var(--text-secondary);
      line-height: 1.7;
    }

    /* Architecture Section */
    .architecture-content {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      gap: 3rem;
    }

    .arch-flow {
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    .arch-node {
      background: var(--bg-card);
      border-radius: 15px;
      padding: 1.5rem;
      text-align: center;
      border: 1px solid var(--border-neon);
      transition: all 0.3s ease;
      flex: 0 0 auto;
    }

    .arch-node:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-neon);
      border-color: var(--neon-cyan);
    }

    .arch-node-icon {
      font-size: 2rem;
      margin-bottom: 1rem;
      display: block;
    }

    .arch-node-title {
      font-family: var(--font-primary);
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
    }

    .arch-node-subtitle {
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    .arch-arrow {
      font-size: 1.5rem;
      color: var(--neon-cyan);
      animation: pulse 2s infinite;
    }

    .arch-details {
      background: var(--bg-card);
      border-radius: 20px;
      padding: 2rem;
      border: 1px solid var(--border-neon);
      max-width: 500px;
    }

    .detail-item {
      display: flex;
      justify-content: space-between;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(0, 255, 255, 0.1);
    }

    .detail-item:last-child {
      border-bottom: none;
    }

    .detail-label {
      color: var(--text-secondary);
    }

    .detail-value {
      font-family: var(--font-primary);
      color: var(--neon-cyan);
    }

    /* Team Section */
    .team-content {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }

    .team-member {
      text-align: center;
      background: var(--bg-card);
      border-radius: 20px;
      padding: 2rem;
      border: 1px solid var(--border-neon);
      transition: all 0.4s ease;
      position: relative;
      overflow: hidden;
    }

    .team-member:hover {
      transform: translateY(-10px);
      box-shadow: var(--shadow-neon-strong);
      border-color: var(--neon-magenta);
    }

    .team-member::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(to right, var(--neon-magenta), var(--neon-yellow), var(--neon-cyan));
    }

    .team-avatar {
      width: 80px;
      height: 80px;
      background: var(--neon-magenta);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-primary);
      font-weight: 600;
      font-size: 1.5rem;
      color: var(--bg-dark);
      margin: 0 auto 1.5rem;
      box-shadow: var(--shadow-neon-strong);
      animation: pulse 3s infinite;
    }

    .team-name {
      font-family: var(--font-primary);
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .team-role {
      font-size: 1.125rem;
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    .team-school {
      display: inline-block;
      background: var(--bg-card);
      color: var(--neon-cyan);
      border: 1px solid var(--border-neon);
      padding: 0.5rem 1rem;
      border-radius: 50px;
      font-size: 0.9rem;
    }

    /* Access Section */
    .access-content {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }

    .access-card {
      background: var(--bg-card);
      border-radius: 20px;
      padding: 2rem;
      border: 1px solid var(--border-neon);
      transition: all 0.4s ease;
      text-align: center;
      position: relative;
    }

    .access-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-neon);
    }

    .access-card:nth-child(1)::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: var(--neon-cyan);
    }

    .access-card:nth-child(2)::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: var(--neon-magenta);
    }

    .access-card:nth-child(3)::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: var(--neon-yellow);
    }

    .access-card:nth-child(4)::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: var(--neon-pink);
    }

    .access-icon {
      font-size: 2.5rem;
      margin-bottom: 1.5rem;
      display: block;
    }

    .access-card:nth-child(1) .access-icon {
      color: var(--neon-cyan);
      text-shadow: var(--shadow-neon);
    }

    .access-card:nth-child(2) .access-icon {
      color: var(--neon-magenta);
      text-shadow: 0 0 10px var(--neon-magenta);
    }

    .access-card:nth-child(3) .access-icon {
      color: var(--neon-yellow);
      text-shadow: 0 0 10px var(--neon-yellow);
    }

    .access-card:nth-child(4) .access-icon {
      color: var(--neon-pink);
      text-shadow: 0 0 10px var(--neon-pink);
    }

    .access-title {
      font-family: var(--font-primary);
      font-size: 1.25rem;
      margin-bottom: 1rem;
    }

    .access-description {
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .access-link {
      display: inline-block;
      margin-top: 1.5rem;
      padding: 0.5rem 1rem;
      background: var(--neon-cyan);
      color: var(--bg-dark);
      border-radius: 50px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .access-link:hover {
      background: var(--neon-magenta);
      transform: translateY(-2px);
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 4rem 2rem 2rem;
      border-top: 1px solid var(--border-neon);
      margin-top: 4rem;
    }

    .footer-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .footer-logo-icon {
      width: 40px;
      height: 40px;
      background: var(--neon-cyan);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: pulse 2s infinite;
    }

    .footer-logo-text {
      font-family: var(--font-primary);
      font-size: 1.5rem;
      background: linear-gradient(to right, var(--neon-cyan), var(--neon-magenta));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .footer-copyright {
      color: var(--text-secondary);
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }

    .footer-links {
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .footer-links a {
      color: var(--text-secondary);
      font-size: 0.9rem;
      transition: all 0.3s ease;
    }

    .footer-links a:hover {
      color: var(--neon-cyan);
      text-shadow: 0 0 5px var(--neon-cyan);
    }

    /* Animations */
    @keyframes pulse {
      0%, 100% {
        opacity: 0.7;
        transform: scale(1);
      }
      50% {
        opacity: 1;
        transform: scale(1.05);
      }
    }

    @keyframes blink {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: 0.3;
      }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      header {
        flex-direction: column;
        height: auto;
        padding: 1rem;
      }

      nav ul {
        margin-top: 1rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      .about-content,
      .architecture-content {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .hero h1 {
        font-size: 2.5rem;
      }

      .hero-actions {
        flex-direction: column;
        align-items: center;
      }

      .team-content,
      .access-content {
        grid-template-columns: 1fr;
      }

      .footer-links {
        flex-direction: column;
        gap: 1rem;
      }
    }

    /* Glitch effect for special elements */
    @keyframes glitch {
      0% {
        text-shadow: 0 0 0 rgba(0,255,255,0),
                     0 0 0 rgba(255,0,255,0),
                     0 0 0 rgba(255,255,0,0);
      }
      20% {
        text-shadow: -2px 0 0 rgba(0,255,255,0.5),
                     2px 0 0 rgba(255,0,255,0.5),
                     -2px 0 0 rgba(255,255,0,0.5);
      }
      40% {
        text-shadow: -2px 0 0 rgba(0,255,255,0.5),
                     2px 0 0 rgba(255,0,255,0.5),
                     -2px 0 0 rgba(255,255,0,0.5);
      }
      60% {
        text-shadow: 0 0 0 rgba(0,255,255,0),
                     0 0 0 rgba(255,0,255,0),
                     0 0 0 rgba(255,255,0,0);
      }
      80% {
        text-shadow: -2px 0 0 rgba(0,255,255,0.5),
                     2px 0 0 rgba(255,0,255,0.5),
                     -2px 0 0 rgba(255,255,0,0.5);
      }
      100% {
        text-shadow: -2px 0 0 rgba(0,255,255,0.5),
                     2px 0 0 rgba(255,0,255,0.5),
                     -2px 0 0 rgba(255,255,0,0.5);
      }
    }

    .glitch-text {
      animation: glitch 3s infinite;
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header>
    <div class="container">
      <div class="logo">
        <div class="logo-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="9" width="18" height="6" rx="1" stroke="currentColor" stroke-width="2"/>
            <circle cx="8" cy="12" r="1.5" fill="currentColor"/>
            <circle cx="16" cy="12" r="1.5" fill="currentColor"/>
            <path d="M3 12H1M23 12H21M8 9V7M16 9V7M8 15V17M16 15V17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="logo-text">OpenRelay</div>
      </div>
      <nav>
        <ul>
          <li><a href="#about">Tentang</a></li>
          <li><a href="#features">Fitur</a></li>
          <li><a href="#architecture">Arsitektur</a></li>
          <li><a href="#team">Tim</a></li>
          <li><a href="#access">Akses</a></li>
        </ul>
      </nav>
      <a href="#access" class="cta-button">Mulai Sekarang</a>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge glitch-text">
          <span class="badge-dot"></span>
          FIKSI 2026 · SMK Negeri 1 Madiun
        </div>

        <h1>
          Kontroler Relay IoT
          <span class="accent">Open Source</span>
        </h1>

        <p class="hero-subtitle">
          Sistem kontrol relay berbasis ESP32 yang memungkinkan pengendalian hingga 128 relay melalui
          protokol MQTT, dengan antarmuka web modern yang dapat diakses dari mana saja.
        </p>

        <div class="hero-actions">
          <a href="#access" class="btn-primary">Coba Dashboard</a>
          <a href="#about" class="btn-outline">Pelajari Lebih Lanjut</a>
        </div>

        <div class="hero-stats">
          <div class="stat">
            <div class="stat-value">128</div>
            <div class="stat-label">Max Relay</div>
          </div>
          <div class="stat">
            <div class="stat-value">ESP32</div>
            <div class="stat-label">Platform</div>
          </div>
          <div class="stat">
            <div class="stat-value">MQTT</div>
            <div class="stat-label">Protokol</div>
          </div>
          <div class="stat">
            <div class="stat-value">100%</div>
            <div class="stat-label">Open Source</div>
          </div>
        </div>

        <!-- Relay Visualizer -->
        <div class="relay-visualizer" id="relay-visualizer"></div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="section">
    <div