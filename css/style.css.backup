body{background:#070a0f;color:#e5e7eb;font-family:"DM Sans",sans-serif}.container{max-width:1000px;margin:auto;padding:20px}.nav-flex{display:flex;justify-content:space-between}.hero{text-align:center;padding:100px 20px}.subtitle{color:#94a3b8}.section{padding:60px 0}.section.alt{background:#121821}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:15px}.card{background:#121821;padding:20px;border-radius:6px;text-align:center}.diagram{display:flex;justify-content:center;gap:10px;margin-top:20px}.box{padding:10px;border:1px solid #1f2937}.highlight{color:#f59e0b}.price{color:#f59e0b}.footer{text-align:center;color:#94a3b8}
h1, h2, h3, h4, h5, h6 { font-family: "Chakra Petch", sans-serif; }