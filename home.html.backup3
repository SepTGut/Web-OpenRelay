  <script>
    // Relay Visualizer Animation
    function initRelayVisualizer() {
      const visualizer = document.getElementById('relay-visualizer');
      if (!visualizer) return;

      // Create relay dots
      const totalDots = 64;
      for (let i = 0; i < totalDots; i++) {
        const dot = document.createElement('div');
        dot.className = 'relay-dot';
        visualizer.appendChild(dot);
      }

      // Animation loop
      function animate() {
        const now = Date.now();
        const dots = visualizer.querySelectorAll('.relay-dot');

        dots.forEach((dot, index) => {
          // Create wave pattern
          const wave = Math.sin(now * 0.002 + index * 0.3);
          const intensity = Math.abs(wave);

          // Determine state based on wave intensity
          if (intensity > 0.8) {
            dot.className = 'relay-dot active';
            dot.style.boxShadow = `0 0 ${8 + intensity * 10}px var(--neon-cyan)`;
          } else if (intensity > 0.5) {
            dot.className = 'relay-dot warning';
            dot.style.boxShadow = `0 0 ${6 + intensity * 8}px var(--neon-yellow)`;
          } else if (intensity > 0.2) {
            dot.className = 'relay-dot error';
            dot.style.boxShadow = `0 0 ${4 + intensity * 6}px var(--neon-magenta)`;
          } else {
            dot.className = 'relay-dot';
            dot.style.boxShadow = 'none';
          }

          // Add slight random variation
          const randomOffset = Math.random() * 0.2;
          dot.style.opacity = 0.7 + randomOffset;
        });

        requestAnimationFrame(animate);
      }

      animate();
    }

    // Initialize on load
    window.addEventListener('load', () => {
      initRelayVisualizer();

      // Add subtle animation to header logo
      const logoIcon = document.querySelector('.logo-icon');
      if (logoIcon) {
        logoIcon.style.animation = 'pulse 3s infinite alternate';
      }
    });

    // Add scroll-triggered animations for sections
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -100px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, observerOptions);

    // Observe all sections
    document.querySelectorAll('section').forEach(section => {
      section.style.opacity = '0';
      section.style.transform = 'translateY(50px)';
      section.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
      observer.observe(section);
    });

    // Add glitch effect to certain elements on hover
    const glitchElements = document.querySelectorAll('.glitch-text, .section-title');
    glitchElements.forEach(element => {
      element.addEventListener('mouseenter', () => {
        element.style.animation = 'glitch 1s infinite';
      });

      element.addEventListener('mouseleave', () => {
        element.style.animation = 'glitch 3s infinite';
      });
    });
  </script>
</body>
</html>