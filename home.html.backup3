            <div style="font-family: var(--font-primary); font-size: 1.25rem; color: var(--neon-cyan); font-weight: 600;">ESP32-Relay</div>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Password</div>
            <div style="font-family: var(--font-primary); font-size: 1.25rem; color: var(--neon-magenta); font-weight: 600;">relay1234</div>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem;">OTA Password</div>
            <div style="font-family: var(--font-primary); font-size: 1.25rem; color: var(--neon-yellow); font-weight: 600;">relay_ota</div>
          </div>
        </div>
      </div>
    </div>
