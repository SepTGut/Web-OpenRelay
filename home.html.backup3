          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="9" width="18" height="6" rx="1" stroke="currentColor" stroke-width="2"/>
            <circle cx="8" cy="12" r="1.5" fill="currentColor"/>
            <circle cx="16" cy="12" r="1.5" fill="currentColor"/>
            <path d="M3 12H1M23 12H21M8 9V7M16 9V7M8 15V17M16 15V17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="footer-logo-text">OpenRelay</div>
      </div>
      <p class="footer-copyright">© 2026 GT & M. Rizky Alfianno · SMK Negeri 1 Madiun · FIKSI 2026</p>
      <div class="footer-links">
        <a href="#about">Tentang</a>
        <a href="#features">Fitur</a>
        <a href="#team">Tim</a>
        <a href="#access">Akses</a>
      </div>
    </div>
