          </div>
          <span class="access-link">TLS/SSL Enabled</span>
        </div>
      </div>

      <!-- WiFi Access Point Info -->
      <div style="text-align: center; margin-top: 4rem; padding: 2rem; background: var(--bg-card); border-radius: 20px; border: 1px solid var(--border-neon); max-width: 500px; margin-left: auto; margin-right: auto;">
        <p style="color: var(--text-secondary); font-size: 1rem; margin-bottom: 1.5rem;">
