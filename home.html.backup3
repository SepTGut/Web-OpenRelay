            <span class="detail-value">SDA: IO21, SCL: IO22</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Interrupt (MCP23017)</span>
            <span class="detail-value">INTA: IO32, INTB: IO33</span>
          </div>
