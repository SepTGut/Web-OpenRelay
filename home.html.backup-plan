    <!-- ── ACCESS ── -->
    <section class="access-section" id="access" aria-labelledby="access-heading">
      <div class="section-inner">

        <div class="section-tag">Akses Proyek</div>
        <h2 class="section-title" id="access-heading">Mulai Sekarang</h2>
        <p class="section-desc">
          Dashboard web bisa langsung diakses dari browser. Firmware dan PCB tersedia untuk dikembangkan lebih lanjut.
        </p>

        <div class="access-content reveal">
          <div class="access-card reveal">
            <div class="access-icon">🌐</div>
            <div class="access-title">Remote Dashboard</div>
            <div class="access-description">
              Dashboard web siap pakai yang dihosting di GitHub Pages. Akses dan kontrol relay dari browser
              menggunakan MQTT over WSS. Tidak butuh instalasi.
            </div>
            <a href="https://github.com/sepgtu/OpenRelay-web" class="access-link" target="_blank">Lihat Repository</a>
          </div>
          <div class="access-card reveal reveal-delay-2">
            <div class="access-icon">📟</div>
            <div class="access-title">Web UI Lokal</div>
            <div class="access-description">
              Akses dashboard lokal langsung dari ESP32 melalui HTTP ke IP perangkat. Tersimpan di LittleFS.
              Tersedia saat tidak ada koneksi internet.
            </div>
            <span class="access-link">http://relaycrtl.local</span>
          </div>
          <div class="access-card reveal reveal-delay-3">
            <div class="access-icon">📡</div>
            <div class="access-title">MQTT Direct</div>
            <div class="access-description">
              Gunakan semua client MQTT yang mendukung (Home Assistant, Node-RED, MQTT Explorer, dsb)
              dengan prefix <code style="font-size:0.9rem">home/relay</code>.
            </div>
            <span class="access-link">broker.hivemq.com : 1883</span>
          </div>
          <div class="access-card reveal reveal-delay-4">
            <div class="access-icon">🔐</div>
            <div class="access-title">Keamanan</div>
            <div class="access-description">
              Enkripsi TLS/SSL untuk koneksi yang aman. Tidak diperlukan kredensial untuk koneksi dasar.
            </div>
            <span class="access-link">TLS/SSL Enabled</span>
          </div>
        </div>

        <!-- WiFi Access Point Info -->
        <div style="text-align: center; margin-top: 4rem; padding: 2rem; background: var(--bg2); border-radius: var(--radius-lg); border: 1px solid var(--border); max-width: 500px; margin-left: auto; margin-right: auto;">
          <p style="color: var(--text-dim); font-size: 1rem; margin-bottom: 1.5rem;">
            WiFi Access Point untuk setup pertama:
          </p>
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
            <div style="text-align: center;">
              <div style="font-size: 0.9rem; color: var(--text-dim); margin-bottom: 0.5rem;">SSID</div>
              <div style="font-family: 'Chakra Petch', monospace; font-size: 1.25rem; color: var(--amber); font-weight: 600;">ESP32-Relay</div>
            </div>
            <div style="text-align: center;">
              <div style="font-size: 0.9rem; color: var(--text-dim); margin-bottom: 0.5rem;">Password</div>
              <div style="font-family: 'Chakra Petch', monospace; font-size: 1.25rem; color: var(--amber); font-weight: 600;">relay1234</div>
            </div>
            <div style="text-align: center;">
              <div style="font-size: 0.9rem; color: var(--text-dim); margin-bottom: 0.5rem;">OTA Password</div>
              <div style="font-family: 'Chakra Petch', monospace; font-size: 1.25rem; color: var(--amber); font-weight: 600;">relay_ota</div>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>

